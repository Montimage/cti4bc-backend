# -------------------------------
# CTI4BC backend configuration template.
# Copy this file to `.env` and adjust the values for your environment:
#     cp .env.example .env
# The real `.env` is gitignored and must never contain committed secrets.
# -------------------------------

# Django
DEBUG=True
# Generate a strong key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=django-insecure-change-me-in-production

# -------------------------------
# Database (PostgreSQL)
# -------------------------------
DB_NAME=cti4bc_db
DB_USER=cti4bc_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# -------------------------------
# Frontend
# -------------------------------
FRONTEND_URL=http://localhost:3000

# -------------------------------
# Allowed hosts / CORS / CSRF (comma-separated)
# For a new deployment, add your domain(s), e.g.:
#   ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,cti4bc.example.com
#   CORS_ALLOWED_ORIGINS=http://localhost:3000,https://cti4bc.example.com
#   CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://cti4bc.example.com
# -------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# -------------------------------
# Kafka (no live broker required to boot;
# consumer only starts on demand via /consumer/start/)
# -------------------------------
KAFKA_SERVER=localhost:9092
KAFKA_USERNAME=kafka_user
KAFKA_PASSWORD=change-me
CTI_REMOTE_TOPIC=CTI4BC.events
RISK_TOPIC=RISK4BC.riskProfile

# -------------------------------
# MISP (optional - set your instance URL and API token)
# Sharing uses the MISPServer DB records; these are kept for completeness.
# -------------------------------
MISP_URL=https://localhost:8443
MISP_TOKEN=CHANGE_ME_MISP_API_TOKEN
MISP_VERIFY_SSL=False

# Risk-evaluation service URL (used as default value of the "RISK EVALUATION"
# MISP attribute). Set to your risk instance for a real deployment.
RISK_URL=http://risk.example.com

# -------------------------------
# Google Forms import (optional)
# Deploy your own Apps Script Web App and paste its /exec URL here.
# Leave empty to disable Google Forms import.
# -------------------------------
GOOGLE_APPS_SCRIPT_URL=

# -------------------------------
# LLM provider (optional - features degrade gracefully without it)
# -------------------------------
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# -------------------------------
# Localization
# -------------------------------
TIME_ZONE=Europe/Paris
